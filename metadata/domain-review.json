{
  "repo": "cinder-move-engine-stack",
  "language": "Elixir",
  "category": "Chess and game engines",
  "goal": "Build an Elixir toolkit that studies engine behavior through fixture event logs, with golden state snapshots and explicit failure cases.",
  "review_model": {
    "terms": [
      "position pressure",
      "move ordering",
      "search width",
      "endgame risk"
    ],
    "lanes": [
      "ship",
      "watch",
      "hold"
    ],
    "score": "signal * 2 + slack + confidence - drag * 3",
    "purpose": "surface the domain-specific cases that need the most careful review"
  },
